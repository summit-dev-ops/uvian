{
  "name": "@org/uvian-automation-api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "platform": "node",
          "outputPath": "apps/uvian-automation-api/dist",
          "format": [
            "cjs"
          ],
          "bundle": false,
          "main": "apps/uvian-automation-api/src/main.ts",
          "tsConfig": "apps/uvian-automation-api/tsconfig.app.json",
          "assets": [
            "apps/uvian-automation-api/src/assets"
          ],
          "esbuildOptions": {
            "sourcemap": true,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "configurations": {
          "development": {},
          "production": {
            "esbuildOptions": {
              "sourcemap": false,
              "outExtension": {
                ".js": ".js"
              }
            }
          }
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@org/uvian-automation-api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@org/uvian-automation-api:build:development"
          },
          "production": {
            "buildTarget": "@org/uvian-automation-api:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@fastify/autoload": "^5.0.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/sensible": "^5.0.0",
    "@org/uvian-events": "*",
    "@supabase/supabase-js": "^2.94.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.0.0",
    "ioredis": "^5.9.2"
  }
}
